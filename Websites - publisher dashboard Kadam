a, a:visited, .intercom-anchor { color: rgb(199, 8, 40); cursor: pointer; }

a:hover, .intercom-anchor:hover { color: rgb(245, 13, 52); }

a:active, .intercom-anchor:active { color: rgb(247, 62, 93); }

@media (-ms-high-contrast: active) {
  .intercom-launcher { background: rgb(20, 22, 26); border: 1px solid rgb(237, 237, 237); }
  [role="button"], button { border: 1px solid rgb(237, 237, 237) !important; background: rgb(20, 22, 26) !important; color: rgb(255, 255, 255) !important; }
  [role="button"]:hover, button:hover, [role="button"]:focus, button:focus, [role="button"]:active, button:active { border: 1px solid rgb(255, 255, 255) !important; background: rgb(20, 22, 26) !important; color: rgb(255, 255, 255) !important; }
  [role="button"] *, button * { color: rgb(255, 255, 255) !important; }
}
